# Personal Assistant Team Environment Variables

# LLM Configuration
SW_LLM_PROVIDER=ollama
SW_LLM_MODEL=llama3.2
SW_LLM_BASE_URL=http://127.0.0.1:11434
SW_LLM_TIMEOUT=180

# API Server
PA_HOST=0.0.0.0
PA_PORT=8015

# Credential Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PA_CREDENTIAL_KEY=

# Storage directories (optional, defaults to .agent_cache/)
PA_PROFILE_DIR=.agent_cache/user_profiles
PA_CREDENTIAL_DIR=.agent_cache/credentials
PA_TASKS_DIR=.agent_cache/tasks
PA_DEALS_DIR=.agent_cache/deals
PA_RESERVATIONS_DIR=.agent_cache/reservations
PA_DOCS_DIR=.agent_cache/documents

# Web Search (Tavily)
TAVILY_API_KEY=

# Google OAuth (for Gmail/Calendar integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft/Outlook OAuth (optional)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
