# Strands stack (docker compose -f docker/docker-compose.yml)
# Copy to .env and set values. Do not commit .env with real secrets.

# ---------------------------------------------------------------------------
# Ollama Cloud (Option A: app talks to https://ollama.com)
# ---------------------------------------------------------------------------
# Create an API key at https://ollama.com/settings/keys
OLLAMA_API_KEY=

# ---------------------------------------------------------------------------
# LLM (agents)
# ---------------------------------------------------------------------------
# Base URL for Ollama: https://ollama.com for cloud, or http://ollama:11434 for local stack
SW_LLM_BASE_URL=https://ollama.com
SW_LLM_MODEL=qwen3.5:397b-cloud
# Optional: request timeout in seconds (default 300). Increase if Ollama Cloud is slow.
SW_LLM_TIMEOUT=600
# Disable "thinking" for qwen3.5 on Ollama Cloud to avoid 500 errors from unsupported think parameter.
SW_LLM_ENABLE_THINKING=false

# ---------------------------------------------------------------------------
# Blogging team — content planning (optional)
# ---------------------------------------------------------------------------
# BLOG_PLANNING_MAX_ITERATIONS=5
# BLOG_PLANNING_MAX_PARSE_RETRIES=3
# Optional: Ollama model name for planning only (defaults to SW_LLM_MODEL)
# BLOG_PLANNING_MODEL=

# ---------------------------------------------------------------------------
# PostgreSQL (stack postgres; default user used for init, temporal/strands created by init script)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ---------------------------------------------------------------------------
# Temporal (uses temporal/temporal database and user created by init script)
# ---------------------------------------------------------------------------
# No extra vars needed; service uses POSTGRES_SEEDS=postgres, POSTGRES_USER=temporal, POSTGRES_PWD=temporal
# For strands-agents (unified API): connect to Temporal for SE team workflows
TEMPORAL_ADDRESS=temporal:7233
# Optional: namespace (default "default"), task queue (default "software-engineering")
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=software-engineering

# ---------------------------------------------------------------------------
# Job Service (centralized job management)
# ---------------------------------------------------------------------------
# URL for the job service container. Teams use this to persist job state.
JOB_SERVICE_URL=http://job-service:8085

# ---------------------------------------------------------------------------
# Logs API (testing only)
# ---------------------------------------------------------------------------
# Set to 1 to enable GET /api/software-engineering/logs (returns supervisor log content)
ENABLE_LOG_API=0

# ---------------------------------------------------------------------------
# Optional: spec file for agents build
# ---------------------------------------------------------------------------
# SPEC_FILE=agents/docker/default_initial_spec.md

# ---------------------------------------------------------------------------
# SE team project workspaces (created via file upload)
# ---------------------------------------------------------------------------
# Base directory where SE team project workspaces are created via file upload.
# Falls back to ENV_WORKSPACE_ROOT if set, then ./se_workspaces relative to CWD.
# SE_WORKSPACE_DIR=/path/to/workspaces
