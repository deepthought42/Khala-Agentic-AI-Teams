# =============================================================================
# Strands Agents — Environment Configuration
# Copy to .env and set values for your deployment.
# All variables are optional unless marked REQUIRED.
# =============================================================================


# =============================================================================
# LLM Provider
# =============================================================================

# Provider: "ollama" (default), "claude", or "dummy" (testing)
LLM_PROVIDER=ollama

# Model name. Defaults to qwen3.5:397b-cloud.
LLM_MODEL=qwen3.5:397b-cloud

# Base URL for the LLM server (Ollama local or Cloud API endpoint)
LLM_BASE_URL=https://ollama.com

# API key — required when using Ollama Cloud API or Claude
OLLAMA_API_KEY=

# Request timeout in seconds (600+ for slow cloud models / long prompts)
LLM_TIMEOUT=600

# Max output tokens per LLM call
LLM_MAX_TOKENS=32768

# Context window size override (tokens). Omit to use model default.
# LLM_CONTEXT_SIZE=

# Retry / backoff settings
LLM_MAX_RETRIES=4
LLM_BACKOFF_BASE=2
LLM_BACKOFF_MAX=60

# Max concurrent LLM requests
LLM_MAX_CONCURRENCY=4

# Per-agent model overrides — uncomment and set to route a specific agent to
# a different model. Key names match internal agent identifiers.
# LLM_MODEL_blog=
# LLM_MODEL_backend=
# LLM_MODEL_frontend=
# LLM_MODEL_devops=
# LLM_MODEL_security=
# LLM_MODEL_qa=
# LLM_MODEL_architect=

# Ollama web search base URL (used by research agents)
# OLLAMA_WEB_SEARCH_BASE_URL=https://ollama.com/api


# =============================================================================
# Temporal Workflow Engine
# When TEMPORAL_ADDRESS is unset, agents run as local threads (default).
# Set it to enable durable, restartable workflows via Temporal.
# =============================================================================

# gRPC address of your Temporal server, e.g. temporal:7233
# TEMPORAL_ADDRESS=

# Temporal namespace (default: "default")
# TEMPORAL_NAMESPACE=default

# Task queue overrides — only needed to change the defaults below
# TEMPORAL_TASK_QUEUE=software-engineering
# TEMPORAL_TASK_QUEUE_BLOGGING=blogging
# TEMPORAL_TASK_QUEUE_PLANNING_V3=planning-v3
# TEMPORAL_TASK_QUEUE_AI_SYSTEMS=ai-systems
# TEMPORAL_TASK_QUEUE_NUTRITION=nutrition-meal-planning
# TEMPORAL_TASK_QUEUE_PA=personal-assistant
# TEMPORAL_TASK_QUEUE_AGENT_PROVISIONING=agent-provisioning


# =============================================================================
# Unified API Server
# =============================================================================

# Bind host and port (used by run_unified_api.py)
UNIFIED_API_HOST=0.0.0.0
UNIFIED_API_PORT=8080

# Security gateway — set to "false" to disable request scanning
SECURITY_GATEWAY_ENABLED=true

# Enable the HTTP log endpoint (GET /api/software-engineering/logs)
ENABLE_LOG_API=0

# Base URL that inter-team adapters use to call each other via the unified API
# UNIFIED_API_BASE_URL=http://localhost:8080

# Frontend URL — used in Slack notifications and planning adapters
UI_BASE_URL=http://localhost:4200


# =============================================================================
# Slack Integration
# =============================================================================

# Incoming webhook URL for job status notifications
# SLACK_WEBHOOK_URL=


# =============================================================================
# Cache & Storage
# =============================================================================

# Root directory for all agent job state, profiles, and artifacts
AGENT_CACHE=.agent_cache


# =============================================================================
# Software Engineering Team
# =============================================================================

# Root directory where SE team project workspaces are created
SE_WORKSPACE_DIR=./se_workspaces

# Security boundary — generated code is confined to this directory
# WORKSPACE_ROOT=

# Time in seconds before a running job is considered stale
JOB_STALE_AFTER_SECONDS=1800

# Enable enterprise architect agents (requires AWS Bedrock credentials)
SW_USE_ENTERPRISE_ARCHITECT=false

# Node Version Manager directory (used when running frontend build commands)
# NVM_DIR=~/.nvm


# =============================================================================
# Personal Assistant Team
# =============================================================================

# API server bind settings
PA_HOST=0.0.0.0
PA_PORT=8015

# Fernet encryption key for stored credentials.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED if using credential storage.
PA_CREDENTIAL_KEY=

# Path to a file containing the encryption key (alternative to PA_CREDENTIAL_KEY)
# PA_CREDENTIAL_KEY_FILE=

# Storage directories (all default to subdirectories of AGENT_CACHE)
# PA_CREDENTIAL_DIR=.agent_cache/credentials
# PA_PROFILE_DIR=.agent_cache/user_profiles
# PA_TASKS_DIR=.agent_cache/tasks
# PA_DEALS_DIR=.agent_cache/deals
# PA_RESERVATIONS_DIR=.agent_cache/reservations
# PA_DOCS_DIR=.agent_cache/documents

# Google OAuth (Gmail / Calendar integration)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Microsoft / Outlook OAuth
# OUTLOOK_CLIENT_ID=


# =============================================================================
# Agent Provisioning Team
# =============================================================================

# Encryption key for provisioning credentials (Fernet format)
# PROVISION_CREDENTIAL_KEY=

# PostgreSQL connection details — used when provisioning Postgres instances
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=postgres

# Redis connection details — used when provisioning Redis instances
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=


# =============================================================================
# Inter-team Adapter URLs (Planning V3 / Branding)
# Override individual team endpoints when not routing through the unified API.
# =============================================================================

# PLANNING_V3_SOFTWARE_ENGINEERING_URL=
# PLANNING_V3_MARKET_RESEARCH_URL=
# PLANNING_V3_AI_SYSTEMS_URL=
# BRANDING_MARKET_RESEARCH_URL=
# BRANDING_DESIGN_SERVICE_URL=


# =============================================================================
# Architect Agents (Enterprise — requires AWS Bedrock)
# Only relevant when SW_USE_ENTERPRISE_ARCHITECT=true
# =============================================================================

# AWS_REGION=us-east-1

# Bedrock model IDs for each architect agent role
# ARCHITECT_MODEL_SPECIALIST=anthropic.claude-sonnet-4-20250514-v1:0
# ARCHITECT_MODEL_ORCHESTRATOR=
# ARCHITECT_MODEL_OBSERVABILITY=

# Output directory for architect agent artefacts
# ARCHITECT_OUTPUT_DIR=./outputs

# Session persistence: "local" uses ARCHITECT_SESSION_DIR; "s3" uses ARCHITECT_SESSION_BUCKET
# ARCHITECT_SESSION_DISABLED=0
# ARCHITECT_SESSION_DIR=
# ARCHITECT_SESSION_BUCKET=
# ARCHITECT_SESSION_PREFIX=sessions/
